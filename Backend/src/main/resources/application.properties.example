spring.application.name=api_jwt
server.port=8000

#--------------------------------------------CONFIGURACION BBDD--------------------------------------------#
spring.datasource.url=jdbc:mysql://${MYSQL_HOST:localhost}:${MYSQL_PORT:3306}/API_SPRING_DB?allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=${MYSQL_USER:root}
spring.datasource.password=${MYSQL_PASSWORD:change_me}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
#--------------------------------------------CONFIGURACION BBDD--------------------------------------------#

app.cors.allowedOrigin=${APP_CORS_ALLOWEDORIGIN:http://localhost:4200}
spring.jpa.hibernate.ddl-auto=update

#---------------------Mensajes de error---------------------#
err.email.exist=Este email ya esta registrado, inicie sesion
err.user.exist=Este usuario ya existe, elija otro nombre
err.user.noExist=Este nombre de usuario no existe
err.password.invalid=El usuario o password son invalidas
err.invalid.id=El usuario con ese id no existe
#---------------------Mensajes de error---------------------#

#------------------------------KEY JWT------------------------------#
key=${JWT_KEY:change_me_generate_a_secure_key}
#------------------------------KEY JWT------------------------------#

#------------------------------Rutas de archivos------------------------------#
app.upload.dir.usuarios=fotos/fotosUsuario/
app.upload.dir.ejercicios=fotos/fotosEjercicios/
#------------------------------Rutas de archivos------------------------------#

spring.jpa.show-sql=true
spring.web.resources.static-locations=file:fotos/
